# ── Seller (server) ──────────────────────────────────────────
# EVM wallet address that will receive USDC payments on Base Sepolia
EVM_ADDRESS=0xYourSellerWalletAddressHere

# OpenAI-compatible LLM backend
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ── Buyer (client + deposit) ─────────────────────────────────
# Private key of the wallet funding inference calls (testnet only — never use mainnet keys)
PRIVATE_KEY=0xYourBuyerPrivateKeyHere

# URL of the running server
RESOURCE_SERVER_URL=http://localhost:4021
